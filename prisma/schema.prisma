generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  STUDENT
  TEACHER
}

enum Gender {
  MALE
  FEMALE
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Prayer {
  FAJR
  SUNRISE
  DHUHR
  ASR
  MAGHRIB
  ISHA
}

enum AlarmSound {
  ADHAN
  BEEP
  CHIME
  SILENT
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  phone       String? @unique
  countryCode String?
  password String

  fullName String
  avatar   String?
  role     Role    @default(USER)
  gender   Gender?
  age      Int?

  provider        AuthProvider @default(EMAIL)
  googleId        String?      @unique
  isEmailVerified Boolean      @default(false)
  isActive        Boolean      @default(true)

  city      String?
  latitude  Float?
  longitude Float?
  language  String  @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminders       PrayerReminder[]
  bookmarks       Bookmark[]
  readingProgress ReadingProgress?
  hadithBookmarks HadithBookmark[]

  @@index([role])
}

model PrayerReminder {
  id            Int        @id @default(autoincrement())
  userId        Int
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayer        Prayer
  enabled       Boolean    @default(true)
  offsetMinutes Int        @default(0)
  alarmSound    AlarmSound @default(ADHAN)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([userId, prayer])
  @@index([userId])
}

model Bookmark {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surahNumber Int
  ayahNumber  Int
  surahName   String?
  note        String?
  createdAt   DateTime @default(now())

  @@unique([userId, surahNumber, ayahNumber])
  @@index([userId])
}

model ReadingProgress {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surahNumber Int
  ayahNumber  Int      @default(1)
  updatedAt   DateTime @updatedAt
}

model HadithBookmark {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hadithId     String
  collectionId String?
  createdAt    DateTime @default(now())

  @@unique([userId, hadithId])
  @@index([userId])
}

model PendingUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String
  phone       String?
  countryCode String?
  role      Role     @default(USER)
  gender    Gender?
  age       Int?
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}
