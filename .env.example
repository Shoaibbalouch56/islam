
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/islam?schema=public"

JWT_SECRET="change-this-to-a-strong-random-secret"

# App branding
APP_NAME="Door-to-Door Islam"
APP_TAGLINE="Illuminate your path with guidance, wisdom & daily reflections"
SUPPORT_EMAIL="support@doortodoorislam.com"

# SMTP (for OTP emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Firebase (required for Google SSO)
# Paste the full service account JSON as a single-line string, or place firebase-service-account.json in project root
FIREBASE_SERVICE_ACCOUNT_JSON=

# Server
PORT=4000
